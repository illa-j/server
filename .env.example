# FreeTAKServer Environment Variables
# Copy this file to .env and fill in your values before deploying.
# NEVER commit the .env file to git — it is already in .gitignore.

# ── Secrets (CHANGE THESE BEFORE DEPLOYING) ──────────────────────
FTS_SECRET_KEY=change-me-to-a-random-string
FTS_FED_PASSWORD=change-me-federation-cert-password
FTS_CLIENT_CERT_PASSWORD=change-me-client-cert-password
FTS_WEBSOCKET_KEY=change-me-websocket-key

# ── Node identity ────────────────────────────────────────────────
FTS_NODE_ID=change-me-to-a-random-32-char-id

# ── Connection message ───────────────────────────────────────────
FTS_CONNECTION_MESSAGE=Welcome to FreeTAKServer

# ── Networking ───────────────────────────────────────────────────
FTS_COT_PORT=8087
FTS_SSLCOT_PORT=8089
FTS_API_PORT=19023
FTS_FED_PORT=9000

FTS_DP_ADDRESS=0.0.0.0
FTS_USER_ADDRESS=0.0.0.0
FTS_API_ADDRESS=0.0.0.0

# ── Internal routing (keep default unless customizing) ───────────
FTS_ROUTING_PROXY_SUBSCRIBE_PORT=19030
FTS_ROUTING_PROXY_SUBSCRIBE_IP=127.0.0.1

FTS_ROUTING_PROXY_PUBLISHER_PORT=19032
FTS_ROUTING_PROXY_PUBLISHER_IP=127.0.0.1

FTS_ROUTING_PROXY_SERVER_PORT=19031
FTS_ROUTING_PROXY_SERVER_IP=127.0.0.1

FTS_INTEGRATION_MANAGER_PULLER_PORT=19033
FTS_INTEGRATION_MANAGER_PULLER_ADDRESS=127.0.0.1

FTS_INTEGRATION_MANAGER_PUBLISHER_PORT=19034
FTS_INTEGRATION_MANAGER_PUBLISHER_ADDRESS=127.0.0.1

# ── Misc settings ────────────────────────────────────────────────
FTS_OPTIMIZE_API=True
FTS_DATA_RECEPTION_BUFFER=1024
FTS_MAX_RECEPTION_TIME=4
FTS_NUM_ROUTING_WORKERS=3
FTS_COT_TO_DB=True
FTS_MAINLOOP_DELAY=100
FTS_EMERGENCY_RADIUS=0
FTS_LOG_LEVEL=info
FTS_DATABASE_TYPE=SQLite
